# App Environment (development / production)
# In production, default weak SECRET_KEY will throw an error.
ENVIRONMENT=development

# JWT security key (Generate a secure random string)
SECRET_KEY=supersecretkeychangeinproduction

# Database URLs
LOCAL_DATABASE_URL=sqlite:///./local_phc.db
# Cloud PostgreSQL URL (uncomment and configure if cloud sync is required)
# CLOUD_DATABASE_URL=postgresql://user:password@host:5432/arogyasync_cloud

# CORS settings: comma-separated list of origins (e.g. http://localhost:3000,http://192.168.1.50)
CORS_ORIGINS=*
